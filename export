import { Component, effect, inject, signal, computed } from '@angular/core';
import { ActivatedRoute } from '@angular/router';

@Component({
  selector: 'app-deal-portfolio',
  templateUrl: './deal-portfolio.component.html',
  styleUrls: ['./deal-portfolio.component.scss'],
  standalone: true
})
export class DealPortfolioComponent {
  private route = inject(ActivatedRoute);

  // On transforme les params en signaux
  id = signal<string | null>(null);
  selectedTab = signal<string | null>(null);

  constructor() {
    // Abonnement aux changements de params (Angular → signals)
    this.route.paramMap.subscribe(params => {
      this.id.set(params.get('id'));
      this.selectedTab.set(params.get('selectedTab'));
    });

    // effet déclenché quand id change OU quand selectedTab vaut 'overview'
    effect(() => {
      const currentId = this.id();
      const tab = this.selectedTab();

      if (currentId && tab === 'overview') {
        this.loadLenderShare(currentId);
      }
    });
  }

  loadLenderShare(id: string) {
    console.log('Loading lender share for deal id:', id);
    // Ici ton vrai appel backend ou logique métier
  }
}